# Caregiver Call Intelligence - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# Anthropic API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=

# HubSpot Service Key (from Settings > Integrations > Service Keys)
HUBSPOT_SERVICE_KEY=

# n8n Webhook URL (from the Webhook node in your workflow)
N8N_WEBHOOK_URL=
